rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados pueden leer y escribir.
    // El control de secciones (views/readOnly) se gestiona en la app.
    // Para endurecer a nivel servidor, reemplazar por reglas por coleccion.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ─── Reglas mas granulares (descomenta cuando se implemente auth por rol) ───
    //
    // match /usuarios/{id} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null && esGerente();
    // }
    //
    // match /permisosConfig/{id} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null && esGerente();
    // }
    //
    // function esGerente() {
    //   return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ["Gerente","Gerente Produccion"];
    // }
  }
}
